**OB-016 — Implement OnboardingController**

Create `src/onboarding/OnboardingController.ts`. This is the state machine that drives the onboarding arc. It evaluates tutorial step triggers and advances the sequence.

```typescript
export class OnboardingController {
  private state: OnboardingState;
  private steps: TutorialStep[];         // all steps from all chapters, sorted by (chapter, sequence)
  private visibilityManager: UIVisibilityManager;
  private pendingTransition: ChapterTransition | null = null;

  constructor(visibilityManager: UIVisibilityManager, steps: TutorialStep[]) {
    this.state = createInitialOnboardingState();
    this.steps = [...steps].sort((a, b) =>
      a.chapter !== b.chapter ? a.chapter - b.chapter : a.sequence - b.sequence
    );
    this.visibilityManager = visibilityManager;
  }

  getState(): Readonly<OnboardingState> { return this.state; }
  getPendingTransition(): ChapterTransition | null { return this.pendingTransition; }

  // Called every tick by the game loop
  tick(game: GameStateView): void {
    if (this.state.isSkipped) return;
    if (this.state.isChapterTransitionPending) return;

    const currentStep = this.getCurrentStep();

    if (currentStep) {
      // Check if advance condition is met
      const canAdvance = currentStep.advanceCondition(game, this.state);
      const minTimeElapsed = (game.getTickCount() - this.state.stepStartTick) >= currentStep.minDisplayTicks;
      if (currentStep.autoAdvanceOnCondition && canAdvance && minTimeElapsed) {
        this.completeStep(currentStep, game);
      }
    } else {
      // Find next step whose trigger is satisfied
      const nextStep = this.findNextStep(game);
      if (nextStep) this.activateStep(nextStep, game);
    }
  }

  // Called by UI when player clicks the advance button
  playerAdvance(game: GameStateView): void {
    const currentStep = this.getCurrentStep();
    if (!currentStep) return;
    if (currentStep.advanceCondition(game, this.state)) {
      this.completeStep(currentStep, game);
    }
  }

  // Called by UI when player dismisses chapter transition card
  dismissTransition(): void {
    this.state.isChapterTransitionPending = false;
    this.pendingTransition = null;
  }

  skipOnboarding(): void {
    // Reveal ALL elements immediately
    const allIds = Object.values(UI_ELEMENTS)
      .filter(v => typeof v === 'string') as string[];
    this.visibilityManager.reveal(allIds);
    this.state.isSkipped = true;
  }

  private getCurrentStep(): TutorialStep | null {
    if (!this.state.currentStepId) return null;
    return this.steps.find(s => s.id === this.state.currentStepId) ?? null;
  }

  private findNextStep(game: GameStateView): TutorialStep | null {
    return this.steps.find(s =>
      !this.state.completedSteps.has(s.id) &&
      s.chapter === this.state.currentChapter &&
      !this.state.currentStepId &&
      s.triggerCondition(game, this.state)
    ) ?? null;
  }

  private activateStep(step: TutorialStep, game: GameStateView): void {
    this.state.currentStepId = step.id;
    this.state.stepStartTick = game.getTickCount();
    this.visibilityManager.applyStep(step);
  }

  private completeStep(step: TutorialStep, game: GameStateView): void {
    this.state.completedSteps.add(step.id);
    this.state.currentStepId = null;
    this.visibilityManager.clearStep(step);

    // Check if this was the last step of the chapter
    const allChapterSteps = this.steps.filter(s => s.chapter === step.chapter);
    const allDone = allChapterSteps.every(s => this.state.completedSteps.has(s.id));
    if (allDone && step.chapter < 8) {
      this.triggerChapterTransition(step.chapter, (step.chapter + 1) as ChapterNumber);
    }
  }

  private triggerChapterTransition(from: ChapterNumber, to: ChapterNumber): void {
    this.state.isChapterTransitionPending = true;
    this.state.currentChapter = to;
    this.state.highestChapterReached = Math.max(this.state.highestChapterReached, to) as ChapterNumber;
    this.pendingTransition = CHAPTER_TRANSITIONS[to];
  }
}
```

**Done when:** Controller instantiates; tick() drives step activation and auto-advance; playerAdvance() works; skipOnboarding() reveals all elements; chapter transitions are queued correctly; unit tests cover: step triggers in correct chapter order, auto-advance fires after minDisplay, manual advance requires condition met.

