**OB-003 — Define UIVisibilityState data structure**

Create `src/onboarding/UIVisibilityState.ts`.

```typescript
export interface UIVisibilityState {
  visible: Set<string>;             // all currently shown element IDs
  dimmed: Set<string>;              // visible but de-emphasized (grayed out)
  spotlit: string | null;           // the currently highlighted element ID
  pulsing: Set<string>;             // elements with pulse animation active
  newlyRevealed: Set<string>;       // elements revealed THIS step (for entrance animation)
}

export function createInitialVisibilityState(): UIVisibilityState {
  return {
    visible: new Set(),             // everything starts HIDDEN
    dimmed: new Set(),
    spotlit: null,
    pulsing: new Set(),
    newlyRevealed: new Set(),
  };
}

export function isVisible(state: UIVisibilityState, elementId: string): boolean {
  return state.visible.has(elementId);
}

export function isDimmed(state: UIVisibilityState, elementId: string): boolean {
  return state.dimmed.has(elementId) && state.visible.has(elementId);
}
```

**Done when:** All types defined; createInitialVisibilityState returns empty sets; helper functions work correctly.

