**OB-015 — Implement UIVisibilityManager**

Create `src/onboarding/UIVisibilityManager.ts`. This class owns the UIVisibilityState and exposes methods to modify it.

```typescript
export class UIVisibilityManager {
  private state: UIVisibilityState;

  constructor() {
    this.state = createInitialVisibilityState();
  }

  getState(): Readonly<UIVisibilityState> { return this.state; }

  reveal(elementIds: string[]): void {
    // Move from hidden to visible; add to newlyRevealed
    elementIds.forEach(id => {
      this.state.visible.add(id);
      this.state.newlyRevealed.add(id);
    });
  }

  hide(elementIds: string[]): void {
    elementIds.forEach(id => {
      this.state.visible.delete(id);
      this.state.dimmed.delete(id);
      this.state.newlyRevealed.delete(id);
    });
  }

  dim(elementIds: string[]): void {
    elementIds.forEach(id => {
      if (this.state.visible.has(id)) this.state.dimmed.add(id);
    });
  }

  undim(elementIds: string[]): void {
    elementIds.forEach(id => this.state.dimmed.delete(id));
  }

  spotlight(elementId: string | null): void {
    this.state.spotlit = elementId;
  }

  pulse(elementIds: string[]): void {
    elementIds.forEach(id => this.state.pulsing.add(id));
  }

  stopPulse(elementIds: string[]): void {
    elementIds.forEach(id => this.state.pulsing.delete(id));
  }

  clearNewlyRevealed(): void {
    this.state.newlyRevealed.clear();
  }

  applyStep(step: TutorialStep): void {
    // Apply all visibility mutations from a step activating
    this.reveal(step.revealElements);
    this.dim(step.dimElements);
    this.undim(step.undimElements);
    if (step.highlightElementId) this.spotlight(step.highlightElementId);
    if (step.highlightMode === 'pulse' && step.highlightElementId) {
      this.pulse([step.highlightElementId]);
    }
  }

  clearStep(step: TutorialStep): void {
    // Clean up spotlight/pulse when a step completes
    this.spotlight(null);
    if (step.highlightElementId) this.stopPulse([step.highlightElementId]);
  }
}
```

**Done when:** All methods implemented; `applyStep` correctly applies all visibility mutations; `clearStep` cleans up; unit tests confirm reveal/hide/dim/undim are independent operations.

