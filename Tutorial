```typescript
export type HighlightMode = 'spotlight' | 'pulse' | 'arrow' | 'border';

export interface TutorialStep {
  id: string;                         // unique key e.g. 'ch1-first-spark'
  chapter: ChapterNumber;
  sequence: number;                   // order within chapter; steps fire in sequence order

  // TRIGGER — when does this step become active?
  // Called each tick. Step activates when this returns true AND previous step is done.
  triggerCondition: (game: GameStateView, onboarding: OnboardingState) => boolean;

  // CONTENT
  headline: string;
  body: string;
  voiceText?: string;                 // same as body but may differ for accessibility

  // UI TARGETING
  highlightElementId: string | null;  // which element to spotlight/pulse
  highlightMode: HighlightMode | null;
  arrowTargetElementId?: string;      // if mode='arrow', draws arrow to this element
  blockInteractionOutsideHighlight: boolean; // true = modal-like, locks rest of UI

  // WHAT TO REVEAL when this step activates
  revealElements: string[];           // element IDs to add to visible set
  dimElements: string[];              // element IDs to add to dimmed set
  undimElements: string[];            // element IDs to remove from dimmed set

  // ADVANCE CONDITIONS
  // Step advances when this returns true OR player clicks advance button
  advanceCondition: (game: GameStateView, onboarding: OnboardingState) => boolean;
  advanceLabel: string;               // '' = no button (auto-advance only)
  autoAdvanceOnCondition: boolean;    // if true, advance without button when condition met
  minDisplayTicks: number;            // minimum time to show step before auto-advance (default 30)
}
```

**Done when:** Interface defined; all fields have sensible types and JSDoc comments.

