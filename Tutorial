**OB-022 — Implement `UIGate` component**

Create `src/onboarding/components/UIGate.tsx`. This is the primary mechanism for making UI elements respect the visibility system. Every game UI element wraps itself in a UIGate.

```typescript
interface UIGateProps {
  elementId: string;
  children: React.ReactNode;
  hiddenMode?: 'unmount' | 'invisible' | 'placeholder';
  // unmount: completely remove from DOM (default for most elements)
  // invisible: render but opacity:0 (preserves layout)
  // placeholder: render a muted grey box at the element's natural size
  className?: string;
}

export function UIGate({ elementId, children, hiddenMode = 'unmount', className }: UIGateProps) {
  const { isVisible, isDimmed, isNewlyRevealed } = useOnboarding();
  const visible = isVisible(elementId);
  const dimmed = isDimmed(elementId);
  const newlyRevealed = isNewlyRevealed(elementId);

  if (!visible) {
    if (hiddenMode === 'unmount') return null;
    if (hiddenMode === 'invisible') return (
      <div style={{ opacity: 0, pointerEvents: 'none' }} className={className}>{children}</div>
    );
    if (hiddenMode === 'placeholder') return (
      <div className={`ui-gate-placeholder ${className ?? ''}`} aria-hidden="true" />
    );
  }

  return (
    <div
      className={[
        'ui-gate',
        dimmed ? 'ui-gate--dimmed' : '',
        newlyRevealed ? 'ui-gate--entering' : '',
        className ?? '',
      ].filter(Boolean).join(' ')}
      data-element-id={elementId}
    >
      {children}
    </div>
  );
}
```

CSS for UIGate:
- `.ui-gate--dimmed`: opacity 0.35, pointer-events none, filter grayscale(60%)
- `.ui-gate--entering`: CSS animation `@keyframes revealFade` — fade in from opacity 0 and slight upward translate over 400ms

**Done when:** UIGate renders children when visible, nothing when hidden (unmount mode); dimmed applies correct CSS; newlyRevealed triggers entrance animation; placeholder renders correct grey box.

