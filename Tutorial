**OB-018 — Implement onboarding skip and restore**

Create `src/onboarding/onboardingPersistence.ts`. Handles saving and restoring onboarding state across sessions.

```typescript
interface SerializedOnboardingState {
  version: number;
  currentChapter: number;
  completedSteps: string[];
  completedChapters: number[];
  highestChapterReached: number;
  isSkipped: boolean;
  suppressedHints: string[];
}

export function serializeOnboarding(state: OnboardingState): string {
  const s: SerializedOnboardingState = {
    version: 1,
    currentChapter: state.currentChapter,
    completedSteps: [...state.completedSteps],
    completedChapters: [...state.completedChapters],
    highestChapterReached: state.highestChapterReached,
    isSkipped: state.isSkipped,
    suppressedHints: [...state.suppressedHints],
  };
  return JSON.stringify(s);
}

export function deserializeOnboarding(json: string): OnboardingState {
  const s: SerializedOnboardingState = JSON.parse(json);
  // version migration handled here
  const state = createInitialOnboardingState();
  state.currentChapter = s.currentChapter as ChapterNumber;
  state.completedSteps = new Set(s.completedSteps);
  state.completedChapters = new Set(s.completedChapters as ChapterNumber[]);
  state.highestChapterReached = s.highestChapterReached as ChapterNumber;
  state.isSkipped = s.isSkipped;
  state.suppressedHints = new Set(s.suppressedHints);
  return state;
}

// When restoring from save, reconstruct which elements should be visible
// by re-applying all chapter reveals up to the saved chapter.
export function reconstructVisibilityFromSave(
  state: OnboardingState,
  visibilityManager: UIVisibilityManager
): void {
  if (state.isSkipped) {
    // Reveal everything
    return; // handled by controller.skipOnboarding()
  }
  for (let ch = 1; ch <= state.highestChapterReached; ch++) {
    applyChapterReveal(ch as ChapterNumber, visibilityManager);
  }
  // Re-apply any step-level reveals from completed steps
  // (steps may reveal things mid-chapter that chapter baseline doesn't)
}
```

