**OB-021 — Implement `useOnboarding` React hook**

Create `src/onboarding/useOnboarding.ts`. This hook connects the OnboardingController to React state so components can read visibility and current step.

```typescript
export function useOnboarding() {
  const [visibilityState, setVisibilityState] = useState<UIVisibilityState>(
    createInitialVisibilityState
  );
  const [onboardingState, setOnboardingState] = useState<OnboardingState>(
    createInitialOnboardingState
  );
  const [pendingTransition, setPendingTransition] = useState<ChapterTransition | null>(null);

  const visibilityManagerRef = useRef(new UIVisibilityManager());
  const controllerRef = useRef<OnboardingController | null>(null);

  // Initialize controller with all steps on mount
  useEffect(() => {
    const allSteps = [...chapter1Steps, ...chapter2Steps, /* ... all 8 chapters */];
    controllerRef.current = new OnboardingController(visibilityManagerRef.current, allSteps);
  }, []);

  // This is called by the game loop each tick
  const onTick = useCallback((game: GameStateView) => {
    controllerRef.current?.tick(game);
    setVisibilityState({ ...visibilityManagerRef.current.getState() });
    setOnboardingState({ ...controllerRef.current!.getState() });
    setPendingTransition(controllerRef.current?.getPendingTransition() ?? null);
  }, []);

  const playerAdvance = useCallback((game: GameStateView) => {
    controllerRef.current?.playerAdvance(game);
    setVisibilityState({ ...visibilityManagerRef.current.getState() });
    setOnboardingState({ ...controllerRef.current!.getState() });
  }, []);

  const dismissTransition = useCallback(() => {
    controllerRef.current?.dismissTransition();
    setOnboardingState({ ...controllerRef.current!.getState() });
    setPendingTransition(null);
  }, []);

  const skipOnboarding = useCallback(() => {
    controllerRef.current?.skipOnboarding();
    setVisibilityState({ ...visibilityManagerRef.current.getState() });
    setOnboardingState({ ...controllerRef.current!.getState() });
  }, []);

  return {
    visibilityState,
    onboardingState,
    pendingTransition,
    onTick,
    playerAdvance,
    dismissTransition,
    skipOnboarding,
    isVisible: (id: string) => visibilityState.visible.has(id),
    isDimmed: (id: string) => visibilityState.dimmed.has(id),
    isSpotlit: (id: string) => visibilityState.spotlit === id,
    isPulsing: (id: string) => visibilityState.pulsing.has(id),
    isNewlyRevealed: (id: string) => visibilityState.newlyRevealed.has(id),
    currentStep: onboardingState.currentStepId,
  };
}
```

