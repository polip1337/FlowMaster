class GameLoop {
  private accumulator: number = 0;
  private lastTime: number = 0;
  private speedMultiplier: number = 1;   // 1, 2, 5, 10
  
  start(): void {
    requestAnimationFrame(this.frame.bind(this));
  }
  
  frame(timestamp: number): void {
    const elapsed = timestamp - this.lastTime;
    this.lastTime = timestamp;
    this.accumulator += elapsed * this.speedMultiplier;
    
    const stepMs = 1000 / TICK_RATE;
    let maxTicksPerFrame = 20;   // cap; prevents spiral of death
    while (this.accumulator >= stepMs && maxTicksPerFrame-- > 0) {
      this.store.dispatch(simulateTick());
      this.accumulator -= stepMs;
    }
    requestAnimationFrame(this.frame.bind(this));
  }
  
  setSpeed(multiplier: 1|2|5|10): void { this.speedMultiplier = multiplier; }
}
```
This correctly handles fast-forward (multiple ticks per frame), prevents spiral of death, and uses the browser's animation scheduler instead of setInterval. Replace TASK-006's SimulationClock with this.

